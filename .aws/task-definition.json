{
  "family": "backjs-task",
  "executionRoleArn": "arn:aws:iam::227809236249:role/LabRole",
  "taskRoleArn": "arn:aws:iam::227809236249:role/LabRole",
  "containerDefinitions": [
    {
      "name": "backend-users",
      "image": "node:20-alpine",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8081,
          "hostPort": 8081,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "PORT",
          "value": "8081"
        },
        {
          "name": "DB_HOST",
          "value": "db-endpoint.rds.amazonaws.com"
        },
        {
          "name": "DB_PORT",
          "value": "3306"
        },
        {
          "name": "DB_NAME",
          "value": "eval_db"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backjs-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}
